# Server
APP_ENV=development
APP_PORT=8080
APP_FRONTEND_ORIGIN=http://localhost:3000

# Database
DB_HOST=localhost
DB_PORT=5433
DB_USER=fintrack
DB_PASSWORD=fintrack
DB_NAME=fintrack
DB_SSLMODE=disable

# JWT
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_EXPIRY_MINUTES=15
JWT_REFRESH_EXPIRY_DAYS=30

# OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
OAUTH_REDIRECT_BASE_URL=http://localhost:3000

# Swagger
SWAGGER_ENABLED=true

# Cloudflare R2 (optional — avatar upload disabled if not set)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_URL=

# Email (SMTP) — leave SMTP_HOST empty to log OTP codes to stdout instead of sending
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=FinTrack <noreply@fintrack.app>
