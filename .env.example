# Server
APP_ENV=development
APP_PORT=8080
APP_FRONTEND_ORIGIN=http://localhost:3000

# Database
DB_HOST=localhost
DB_PORT=5433
DB_USER=fintrack
DB_PASSWORD=fintrack
